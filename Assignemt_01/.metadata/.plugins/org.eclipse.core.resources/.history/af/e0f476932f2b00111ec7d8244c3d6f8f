#include "led.h"

void delay_ms(uint32_t ms)
{
	for(uint32_t i = 0; i < ms * 4000; i++);
}

int main(void)
{
	// Initialize LED pins
	led_init(12);
	led_init(13);
	led_init(14);
	led_init(15);

	while(1)
	{
		led_on(12);
		delay_ms(300);

		led_on(13);
		delay_ms(300);

		led_on(14);
		delay_ms(300);

		led_on(15);
		delay_ms(300);


		led_off(15);
		delay_ms(300);

		led_off(14);
		delay_ms(300);

		led_off(13);
		delay_ms(300);

		led_off(12);
		delay_ms(300);
	}
}










