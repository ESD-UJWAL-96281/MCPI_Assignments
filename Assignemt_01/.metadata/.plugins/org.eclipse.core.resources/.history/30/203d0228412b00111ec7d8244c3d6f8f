#include "led.h"
#include "switch.h"

void delay_ms(uint32_t ms)
{
	for(uint32_t i=0; i<ms*4000; i++);
}

int main(void)
{
	uint8_t mode = 0;

	// LED init (PD12-PD15)
	led_init(12);
	led_init(13);
	led_init(14);
	led_init(15);

	// Switch init (PA0)
	switch_init(0);

	while(1)
	{
		// if switch pressed
		if(switch_status(0) == 1)
		{
			delay_ms(200);            // debounce

			// wait until switch released
			while(switch_status(0) == 1);

			// change mode
			mode++;
			if(mode > 4)
				mode = 0;
		}

		// turn OFF all LEDs first
		led_off(12);
		led_off(13);
		led_off(14);
		led_off(15);

		// pattern selection
		if(mode == 0)
		{
			// Pattern 0: All OFF
		}
		else if(mode == 1)
		{
			// Pattern 1: Only PD12
			led_on(12);
		}
		else if(mode == 2)
		{
			// Pattern 2: Only PD13
			led_on(13);
		}
		else if(mode == 3)
		{
			// Pattern 3: Alternate LEDs
			led_on(12);
			led_on(14);
		}
		else if(mode == 4)
		{
			// Pattern 4: All LEDs ON
			led_on(12);
			led_on(13);
			led_on(14);
			led_on(15);
		}
	}
}










